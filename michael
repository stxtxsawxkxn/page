<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>chat</title>


<style>
html,
body {
  margin: 0;
  background: #151515;
  overflow: hidden;
  font-family: sans-serif;
}

.top-bar {
  position: fixed;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 100%;
  max-width: 500px;
  z-index: 100;
  background: #151515;
}

.top-bar img {
  width: 100%;
  display: block;
}

.chat-scroll {
  height: 100dvh;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #151515;
  padding-top: min(13.72vw, 68.6px);
  box-sizing: border-box;
    line-height: 0;
  font-size: 0;
}

.chat-scroll img {
  width: 100%;
  max-width: 500px;
  display: block;
}

  .bottom-bar {
  position: fixed;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 100%;
  max-width: 500px;
  z-index: 100;
  background: #151515;
}

.bottom-bar img {
  width: 100%;
  display: block;
}

  
</style>
</head>

<body>

  <div class="top-bar">
    <img src="MICHAEL_000.png">
  </div>

  <div class="chat-scroll">

    <img src="MICHAEL_001.png">
  </div>

</body>
</html>
